  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/index.ts",
    "build:client": "vite build",
    "build:server": "tsx script/build-server.ts",
    "build": "tsx script/build.ts",
    "start": "cross-env NODE_ENV=production node script/run-supervised.js node dist/index.js",
    "start:once": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test": "vitest run --root .",
