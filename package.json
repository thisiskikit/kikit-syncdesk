    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "lucide-react": "^0.525.0",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-data-grid": "7.0.0-beta.49",
    "react-dom": "^19.1.1",
    "wouter": "^3.7.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/papaparse": "^5.3.16",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
