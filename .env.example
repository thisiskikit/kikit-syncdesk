DATABASE_URL=
MASTER_SKU_DATABASE_URL=

# Preferred app port. APP_PORT takes precedence over PORT.
APP_PORT=5000
PORT=5000
HOST=0.0.0.0
SERVE_CLIENT_STATIC=true
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend API base URL. Leave blank for same-origin local development.
VITE_API_BASE_URL=

# File-backed stores. For hosted backend, point these to your persistent disk.
LOG_DIR=data/logs
OPERATION_LOG_FILE=data/operation-logs.json
LOG_RETENTION_DAYS=14
LOG_MAX_TOTAL_MB=25
LOG_SLOW_API_MS=800
LOG_SLOW_EXTERNAL_MS=1000
UI_STATE_FILE=data/ui-state.json
CHANNEL_SETTINGS_FILE=data/channel-settings.json
COUPANG_SETTINGS_FILE=data/coupang-settings.json
COUPANG_PRODUCT_CACHE_FILE=data/coupang-product-cache.json
NAVER_PRODUCT_CACHE_FILE=data/naver-product-cache.json
NAVER_PRODUCT_SELLER_BARCODE_CACHE_FILE=data/naver-product-seller-barcode-cache.json
NAVER_PRODUCT_MEMO_FILE=data/naver-product-memos.json
COUPANG_SHIPMENT_WORKSHEET_FILE=data/coupang-shipment-worksheet.json
COUPANG_BULK_PRICE_FILE=data/coupang-bulk-price.json
NAVER_BULK_PRICE_FILE=data/naver-bulk-price.json

NAVER_COMMERCE_AUTH_URL=https://api.commerce.naver.com/external/v1/oauth2/token
NAVER_COMMERCE_API_BASE_URL=https://api.commerce.naver.com/external
